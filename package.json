{
	"name": "jaset",
	"version": "2.0.0",
	"description": "A simple, type-safe implementation of EventTarget with zero dependencies and select enhancements for a better developer experience.",
	"keywords": [
		"eventtarget",
		"event target",
		"event emitter",
		"event",
		"typescript"
	],
	"homepage": "https://jaset.js.org",
	"bugs": {
		"url": "https://github.com/maxherrmann/jaset/issues"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/maxherrmann/jaset.git"
	},
	"author": {
		"name": "Max Herrmann",
		"email": "npm@max-herrmann.com",
		"url": "https://github.com/maxherrmann"
	},
	"funding": "https://github.com/sponsors/maxherrmann",
	"license": "MIT",
	"engines": {
		"node": ">=18"
	},
	"type": "module",
	"sideEffects": false,
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"format": "prettier --write .",
		"lint": "eslint . && tsc --noEmit",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage"
	},
	"devDependencies": {
		"@arethetypeswrong/core": "^0.18.3",
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@tsconfig/recommended": "^1.0.13",
		"@vitest/coverage-v8": "^4.1.9",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-tsdoc": "^0.5.2",
		"prettier": "^3.8.4",
		"publint": "^0.3.21",
		"tsdown": "^0.22.2",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.0",
		"vitest": "^4.1.9"
	}
}
