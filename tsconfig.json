{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "@tsconfig/recommended",
	"compilerOptions": {
		"declaration": true,
		"emitDeclarationOnly": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"noEmitOnError": true,
		"outDir": "./dist",
		"rootDir": "./src",
		"strict": true,
		"target": "esnext",
		"verbatimModuleSyntax": true
	},
	"include": ["./src/**/*.ts"]
}
